# ============================================================================
# Sentinelle — Environment variables for self-hosted deploy
# ============================================================================

# ----- Frontend (Vite) -------------------------------------------------------
VITE_SUPABASE_URL=https://supabase.easychain.com.br
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# ----- Edge Functions / Supabase backend ------------------------------------
SUPABASE_URL=https://supabase.easychain.com.br
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgres://postgres:<password>@db.easychain.com.br:5432/postgres

# ----- LLM defaults (optional global fallback) ------------------------------
# Each client can override these in Settings > Integrations.
# Supported providers: groq | openai | anthropic | gemini | mistral | cohere | lovable
DEFAULT_LLM_PROVIDER=groq
DEFAULT_LLM_API_KEY=
DEFAULT_LLM_MODEL=llama-3.1-8b-instant

# ----- Lovable AI Gateway (optional) ----------------------------------------
# Only needed if you want to keep using Lovable AI as a fallback.
# Leave blank when running fully self-hosted.
LOVABLE_API_KEY=

# ----- WhatsApp Bridge (UAZAPI) ---------------------------------------------
WHATSAPP_BRIDGE_TOKEN=
WHATSAPP_BRIDGE_URL=

# ----- Meta (Facebook / Instagram) ------------------------------------------
META_WEBHOOK_VERIFY_TOKEN=

# ----- Web Push Notifications (VAPID) ---------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@yourdomain.com
